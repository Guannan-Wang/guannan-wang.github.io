source 'https://rubygems.org'

# Match the GitHub Pages build runtime: actions/jekyll-build-pages runs the
# github-pages gem (v232 → Jekyll 3.10.x). Pinning it here keeps the
# Codespace preview identical to the deployed build.
gem 'github-pages', '~> 232', group: :jekyll_plugins

gem 'webrick', '~> 1.8'            # required by `jekyll serve` on Ruby 3+
gem 'connection_pool', '2.5.0'     # pin carried over from upstream template
